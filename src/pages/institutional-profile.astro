---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';

const contents = [
  'About Academia Europa',
  'Legal operator: Solex Education Unipessoal LDA, Portugal',
  'Institutional mission',
  'Educational philosophy',
  'Academic standards',
  'Academic governance',
  'Veterinary Academy International (VAI) overview',
  'Future academies in development',
  'CPD/CE alignment approach',
  'Faculty standards',
  'Certificate policy',
  'Contact for academic review',
];
---
<Base
  title="Institutional Profile · Academia Europa"
  description="The Academia Europa Institutional Profile summarises the institution's purpose, educational philosophy, academic governance, programme development model, and professional review approach. Intended for academic reviewers, professional bodies, faculty, and institutional partners."
>
  <PageHero
    eyebrow="For Reviewers and Partners"
    title="Academia Europa Institutional Profile."
    lede="A summary of the institution's purpose, educational philosophy, academic governance, programme development model, and professional review approach."
  />

  <Section eyebrow="Who It Is For">
    <div class="prose-editorial max-w-3xl">
      <p>The Academia Europa Institutional Profile is intended for academic reviewers, professional bodies, faculty, institutional partners, and organisations considering collaboration. It consolidates the documentation that supports professional review in a single, structured reference.</p>
    </div>
  </Section>

  <Section eyebrow="What the Profile Contains" tone="ivory">
    <ul class="grid md:grid-cols-2 gap-3 max-w-3xl">
      {contents.map((c) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-champagne text-xs">—</span><span>{c}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Request the Profile" title="Available upon request.">
    <div class="prose-editorial max-w-3xl">
      <p><strong class="text-navy-deep font-medium">Academia Europa Institutional Profile 2026</strong> is available on request to qualifying parties. A downloadable version is in preparation.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/contact" class="btn">Request the Institutional Profile</a>
        <a href="mailto:academic@academiaeuropa.com" class="btn">Email the Academic Office</a>
      </div>
    </div>
  </Section>
</Base>
