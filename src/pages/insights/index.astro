---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';

const all = await getCollection('insights', ({ data }) => !data.draft);
const articles = all.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base
  title="Insights"
  description="Editorial perspectives on professional education, clinical mastery, evidence, and the practice of learning."
>
  <PageHero
    eyebrow="Insights"
    title="Editorial Perspectives."
    lede="On professional education, veterinary medicine, evidence, ethics, and the practice of mastery."
  />

  <Section>
    {articles.length === 0 ? (
      <p class="text-graphite leading-relaxed max-w-2xl">Insights articles will be published here. The first article is forthcoming.</p>
    ) : (
      <ul class="max-w-4xl divide-y divide-platinum">
        {articles.map((a) => (
          <li class="py-10">
            <div class="eyebrow mb-3">{a.data.category}</div>
            <h3 class="font-serif text-2xl md:text-3xl text-cream leading-snug mb-3">
              <a href={`/insights/${a.id}`} class="hover:text-bronze transition-colors">{a.data.title}</a>
            </h3>
            <p class="text-graphite leading-relaxed max-w-2xl mb-4">{a.data.description}</p>
            <div class="text-sm text-muted">{fmt(a.data.publishedAt)} · {a.data.author}</div>
          </li>
        ))}
      </ul>
    )}
  </Section>
</Base>
