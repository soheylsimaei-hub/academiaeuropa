---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';

const stages = [
  { n: '01', t: 'Needs analysis', d: 'Identifying the professional gap a programme is intended to address.' },
  { n: '02', t: 'Learning objective design', d: 'Articulating, in plain language, what completion will mean.' },
  { n: '03', t: 'Curriculum mapping', d: 'Sequencing modules and assessments into a coherent path.' },
  { n: '04', t: 'Faculty selection', d: 'Matched to subject and our standards (see below).' },
  { n: '05', t: 'Content development', d: 'Produced to defined academic and editorial criteria.' },
  { n: '06', t: 'Evidence review', d: 'Every claim graded against the evidence hierarchy.' },
  { n: '07', t: 'Academic review', d: 'Final review before publication.' },
  { n: '08', t: 'Versioning & update cycle', d: 'Defined review intervals after publication.' },
];

const evidence = [
  { l: 'Level 1', t: 'Strong Clinical Evidence', d: 'Established, replicated, clinically accepted.' },
  { l: 'Level 2', t: 'Emerging Clinical Evidence', d: 'Early but credible clinical data.' },
  { l: 'Level 3', t: 'Preclinical or Mechanistic', d: 'Laboratory or translational; not yet clinical.' },
  { l: 'Level 4', t: 'Expert Hypothesis', d: 'Reasoned perspective; clearly labelled as such.' },
];
---
<Base
  title="Academic Governance & Quality Assurance · Academia Europa"
  description="Documented governance, course development process, faculty standards, evidence framework, assessment philosophy, certificate policy, and CPD/CE alignment."
>
  <PageHero
    eyebrow="Governance"
    title="Academic Governance & Quality Assurance."
    lede="How Academia Europa designs, documents, reviews, and maintains its professional education programmes. Built to be structured, review-ready, and aligned with responsible postgraduate professional education."
  />

  <Section eyebrow="01. Governance Philosophy">
    <div class="prose-editorial max-w-3xl">
      <p>Academia Europa is building a structured academic governance model designed for postgraduate professional education. Our governance is documented, reviewable, and continuously refined as the institution and its academies mature.</p>
    </div>
  </Section>

  <Section eyebrow="02. Course Development Process" title="Every programme passes through eight defined stages." tone="ivory">
    <ol class="grid md:grid-cols-2 gap-x-12 gap-y-10 max-w-5xl">
      {stages.map((s) => (
        <li>
          <div class="font-serif text-champagne text-xs tracking-[0.3em] mb-2">{s.n}</div>
          <h3 class="font-serif text-xl text-navy-deep mb-2">{s.t}</h3>
          <p class="text-graphite leading-relaxed">{s.d}</p>
        </li>
      ))}
    </ol>
  </Section>

  <Section eyebrow="03. Faculty Standards" title="Selected on substance.">
    <div class="prose-editorial max-w-3xl">
      <p>Faculty selection is governed by: relevant professional qualification, demonstrable experience, evidence-based teaching practice, ethical communication, respect for clinical uncertainty, declared conflicts of interest, and the ability to teach within a structured curriculum.</p>
    </div>
  </Section>

  <Section eyebrow="04. Evidence Framework" title="Four levels, applied openly." tone="ivory">
    <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
      {evidence.map((e) => (
        <div class="border-l-2 border-champagne pl-6 py-2">
          <div class="eyebrow mb-2">{e.l}</div>
          <h3 class="font-serif text-xl text-navy-deep mb-2">{e.t}</h3>
          <p class="text-graphite leading-relaxed text-sm">{e.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="05. Review & Update Cycle" title="Versioned. Reviewed. Refreshed.">
    <div class="prose-editorial max-w-3xl">
      <p>Every programme carries a version date. References are reviewed periodically. Emerging areas are updated when evidence changes. Learners are shown the last-review date of every module.</p>
    </div>
  </Section>

  <Section eyebrow="06. Assessment Philosophy" title="Confirming understanding, not enforcing compliance." tone="ivory">
    <div class="prose-editorial max-w-3xl">
      <p>Assessments include case-based questions, reflective application, structured knowledge checks, and, where appropriate, practical exercises. Certificate eligibility is tied to defined completion criteria.</p>
    </div>
  </Section>

  <Section eyebrow="07. Certificate Policy" title="Honest about what they document.">
    <div class="prose-editorial max-w-3xl">
      <p>Certificates issued by Academia Europa document completion of structured postgraduate professional learning. They <strong class="text-navy-deep font-medium">do not confer specialist status, board certification, or state academic degree equivalence</strong> unless explicitly stated and formally recognised by the relevant authority.</p>
    </div>
  </Section>

  <Section eyebrow="08. CPD/CE Alignment" title="Submitted only when designed for review." tone="ivory">
    <div class="prose-editorial max-w-3xl">
      <p>Programmes are designed to support CPD/CE review. Selected programmes may be submitted to relevant external bodies. <strong class="text-navy-deep font-medium">No external accreditation, approval, or credit allocation is claimed unless it has been formally granted</strong>, and any such status is communicated only after formal confirmation.</p>
    </div>
  </Section>

  <Section eyebrow="09. Ethical Education Principles" title="What we will not do.">
    <div class="prose-editorial max-w-3xl">
      <p>We do not promote unproven clinical claims, exaggerated outcomes, or interventions outside the bounds of current evidence. Programmes are written to teach innovation responsibly, distinguishing what is known, what is emerging, what is mechanistic, and what is hypothesis.</p>
    </div>
  </Section>

  <Section eyebrow="10. Institutional Review Contact" tone="ivory">
    <div class="prose-editorial max-w-3xl">
      <p>For academic review, CPD/CE enquiries, or institutional collaboration:</p>
      <p><a href="mailto:academic@academiaeuropa.com" class="font-serif text-xl md:text-2xl text-navy-deep hover:text-champagne transition-colors">academic@academiaeuropa.com</a></p>
    </div>
  </Section>
</Base>
