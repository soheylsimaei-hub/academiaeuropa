---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';

const pathways = [
  { t: 'General Enquiries', e: 'hello@academiaeuropa.com' },
  { t: 'Faculty Enquiries', e: 'faculty@academiaeuropa.com' },
  { t: 'Partnerships & Academic Review', e: 'partnerships@academiaeuropa.com' },
  { t: 'Academic Office', e: 'academic@academiaeuropa.com' },
  { t: 'Media & Press', e: 'press@academiaeuropa.com' },
];
---
<Base
  title="Contact Academia Europa"
  description="Professional, faculty, partnership, academic review, and media enquiries for Academia Europa."
>
  <PageHero
    eyebrow="Contact"
    title="Contact Academia Europa."
    lede="For professional, faculty, partnership, academic review, and media enquiries."
  />

  <Section eyebrow="Send an Enquiry" title="Use the form below, or reach the relevant office directly.">
    <ContactForm />
  </Section>

  <Section eyebrow="Direct Pathways" tone="ivory">
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-12 max-w-4xl">
      {pathways.map((p) => (
        <div class="border-t border-platinum pt-6">
          <div class="eyebrow mb-3">{p.t}</div>
          <a href={`mailto:${p.e}`} class="font-serif text-xl md:text-2xl text-navy-deep hover:text-champagne transition-colors">{p.e}</a>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Institutional Information">
    <div class="prose-editorial max-w-3xl">
      <p>Academia Europa is operated by <strong class="text-navy-deep font-medium">Solex Education Unipessoal LDA</strong>, registered in Portugal.</p>
    </div>
  </Section>
</Base>
