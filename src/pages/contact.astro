---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';

const pathways = [
  {
    t: 'General & Administrative Enquiries',
    e: 'admin@academiaeuropa.com',
    d: 'For general enquiries, administrative communication, website enquiries, and operational matters.',
  },
  {
    t: 'Academic Office',
    e: 'academic@academiaeuropa.com',
    d: 'For academic review, programme documentation, CPD/CE-related enquiries, and professional education matters.',
  },
  {
    t: 'Partnerships & Faculty Collaboration',
    e: 'partnerships@academiaeuropa.com',
    d: 'For institutional partnerships, faculty collaboration, programme co-development, and future academy discussions.',
  },
];
---
<Base
  title="Contact Academia Europa"
  description="General, academic, and partnership enquiries for Academia Europa."
>
  <PageHero
    eyebrow="Contact"
    title="Contact Academia Europa."
    lede="For general enquiries, academic review, or institutional collaboration, please use the appropriate pathway below."
  />

  <Section eyebrow="Send an Enquiry" title="Use the form below, or reach the relevant office directly.">
    <ContactForm />
  </Section>

  <Section eyebrow="Direct Pathways" title="Reach the appropriate office directly." tone="ivory">
    <ul class="max-w-4xl border-t border-platinum">
      {pathways.map((p) => (
        <li class="grid md:grid-cols-12 gap-6 md:gap-10 items-baseline py-8 border-b border-platinum">
          <div class="md:col-span-4">
            <div class="eyebrow">{p.t}</div>
          </div>
          <div class="md:col-span-5 text-graphite leading-relaxed text-[15px]">{p.d}</div>
          <div class="md:col-span-3 md:text-right">
            <a href={`mailto:${p.e}`} class="text-[15px] tracking-tight text-cream hover:text-bronze transition-colors whitespace-nowrap">{p.e}</a>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Institutional Information">
    <div class="prose-editorial max-w-5xl">
      <p>Academia Europa is operated by <strong class="text-cream font-medium">Solex Education Unipessoal LDA</strong>, registered in Portugal.</p>
    </div>
  </Section>
</Base>
