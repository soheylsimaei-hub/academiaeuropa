---
// Legacy URL — redirect any old /about/founder traffic to /about/leadership
const target = '/about/leadership';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Leadership · Academia Europa</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={`https://academiaeuropa.com${target}`} />
    <meta name="robots" content="noindex" />
    <script type="text/javascript" set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </head>
  <body>
    <p>Redirecting to <a href={target}>Leadership</a>.</p>
  </body>
</html>
