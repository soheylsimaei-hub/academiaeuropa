---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
---
<Base
  title="Leadership · Academia Europa"
  description="Academia Europa was established under experienced institutional leadership and is being developed as a multi-disciplinary platform for postgraduate professional education across specialised fields."
>
  <PageHero
    eyebrow="Leadership"
    title="Institutional Leadership."
    lede="Academia Europa is being developed as a long-term, multi-disciplinary platform for structured postgraduate professional education."
  />

  <Section>
    <div class="prose-editorial max-w-3xl">
      <p>Academia Europa was established under the leadership of <strong class="text-navy-deep font-medium">Dr. Soheyl Simaei</strong>, a clinician, entrepreneur, and education founder with more than two decades of clinical practice, professional leadership, and educational entrepreneurship. This experience now informs his work in building structured postgraduate professional education.</p>
      <p>Academia Europa begins with veterinary medicine through Veterinary Academy International, while the institution is being developed as a broader multi-disciplinary platform for postgraduate professional education in additional fields over time.</p>
      <p>Academia Europa is operated by <strong class="text-navy-deep font-medium">Solex Education Unipessoal LDA</strong>, registered in Portugal.</p>
    </div>
  </Section>

  <Section eyebrow="Roles" tone="ivory">
    <ul class="space-y-3 text-graphite text-lg max-w-3xl">
      <li class="flex gap-4 items-baseline"><span class="text-champagne text-xs tracking-[0.2em]">—</span> Founder & Chief Executive Officer, Academia Europa</li>
      <li class="flex gap-4 items-baseline"><span class="text-champagne text-xs tracking-[0.2em]">—</span> Founder, Veterinary Academy International (VAI)</li>
    </ul>
  </Section>
</Base>
