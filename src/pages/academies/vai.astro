---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';

const audience = [
  'Veterinarians with three or more years of practice',
  'Veterinary specialists and surgeons',
  'Practice owners and clinical leaders',
  'Veterinary educators',
  'Veterinary teams seeking structured CPD/CE',
  'Practitioners pursuing professional sustainability and longevity in their careers',
];

const differentiators = [
  'Case-based, clinically grounded teaching',
  'Expert-led instruction',
  'Documented evidence levels in every module',
  'Structured progression rather than disconnected webinars',
  'Academic standards prepared for CPD/CE review',
  'A long-term institutional home, not a course marketplace',
];

const directions = [
  'Clinical Mastery',
  'Veterinary Leadership and Practice',
  'Faculty-led Subject Series',
  'Professional Sustainability for Veterinary Teams',
];
---
<Base
  title="VAI · Veterinary Academy International"
  description="The veterinary education arm of Academia Europa. Structured postgraduate veterinary education, evidence-based and expert-led."
>
  <PageHero
    eyebrow="Veterinary Academy International"
    title="The Veterinary Education Arm of Academia Europa."
    lede="Structured, evidence-based postgraduate education for veterinarians and veterinary teams."
  />

  <Section eyebrow="Our Purpose" title="From clinical competence to clinical mastery · and beyond.">
    <div class="prose-editorial max-w-5xl">
      <p>Veterinary Academy International was created to give veterinarians something the wider CPD landscape rarely offers: a structured, expert-led, evidence-aware path from clinical competence to clinical mastery, and beyond, to leadership in the profession.</p>
    </div>
  </Section>

  <Section eyebrow="Who We Serve" title="Built for experienced practitioners." tone="ivory">
    <ul class="grid md:grid-cols-2 gap-4 max-w-5xl">
      {audience.map((a) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-bronze text-xs">—</span><span>{a}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="What Makes VAI Different">
    <ul class="grid md:grid-cols-2 gap-4 max-w-5xl">
      {differentiators.map((d) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-bronze text-xs">—</span><span>{d}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Programme Directions" title="Where our education leads." tone="ivory">
    <ul class="grid md:grid-cols-2 gap-6 max-w-4xl">
      {directions.map((d, i) => (
        <li class="border-t border-platinum pt-5">
          <div class="font-serif text-bronze text-xs tracking-[0.3em] mb-2">0{i + 1}</div>
          <div class="font-serif text-xl text-cream">{d}</div>
        </li>
      ))}
    </ul>
    <div class="mt-12 max-w-5xl prose-editorial">
      <p>Programme detail, current educational directions, and the full course catalogue are available on the dedicated VAI platform.</p>
      <div class="mt-4">
        <a href="https://vai.vet" rel="noopener" class="btn">Visit VAI</a>
      </div>
    </div>
  </Section>

  <Section eyebrow="The Dedicated VAI Platform" tone="ivory">
    <div class="prose-editorial max-w-5xl">
      <p>The dedicated platform for Veterinary Academy International is available at <strong class="text-cream font-medium">vai.vet</strong>, with full programme detail, faculty information, and the academy's current educational directions.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="https://vai.vet" rel="noopener" class="btn">Visit VAI</a>
        <a href="/contact" class="btn">Register Interest</a>
      </div>
    </div>
  </Section>
</Base>
