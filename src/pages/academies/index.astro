---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import BrandArchitectureDiagram from '../../components/BrandArchitectureDiagram.astro';

const future = ['Medicine', 'Dentistry', 'Pharmacy', 'Law', 'Technology', 'Business & Leadership'];

const sharedStandards = [
  'Defined learning objectives',
  'Structured modules and assessment',
  'Documented faculty profiles',
  'Evidence-level distinctions in content',
  'Versioned references and review cycles',
  'Transparent certificate criteria',
  'Ethical communication and professional relevance',
];
---
<Base
  title="Professional Academies · Academia Europa"
  description="Specialised academies under one European institutional home. Beginning with Veterinary Academy International, with a multi-disciplinary architecture across professional fields."
>
  <PageHero
    eyebrow="Professional Academies"
    title="The Academy Model."
    lede="Academia Europa is designed as the institutional home for specialised professional academies. Each academy focuses on a defined professional field while sharing a common commitment to structured learning, evidence-informed education, academic documentation, ethical communication, and professional relevance."
  />

  <Section eyebrow="Architecture" title="One institution. Specialised academies.">
    <BrandArchitectureDiagram />
  </Section>

  <Section eyebrow="First Academy" tone="ivory">
    <div class="grid md:grid-cols-12 gap-12 items-start max-w-5xl">
      <div class="md:col-span-5">
        <h2 class="font-serif text-3xl md:text-4xl text-navy-deep leading-tight">Veterinary Academy International</h2>
        <div class="rule-gold mt-6"></div>
      </div>
      <div class="md:col-span-7 prose-editorial">
        <p>Veterinary Academy International is the first specialised academy of Academia Europa, dedicated to postgraduate veterinary education and professional development.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/academies/vai" class="btn">Discover VAI</a>
          <a href="https://vai.vet" rel="noopener" class="btn">Visit VAI</a>
        </div>
      </div>
    </div>
  </Section>

  <Section eyebrow="Future Professional Fields" title="A multi-disciplinary trajectory.">
    <div class="prose-editorial max-w-3xl mb-10">
      <p>Over time, Academia Europa is designed to support additional academies in fields such as those below. Each future academy will be developed with field-specific experts, appropriate academic documentation, and professional review standards.</p>
    </div>
    <ul class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-3xl">
      {future.map((f) => (
        <li class="border-t border-platinum pt-4 text-navy-deep font-serif text-xl">{f}</li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Shared Institutional Standards" title="What every academy shares." tone="ivory">
    <ul class="grid md:grid-cols-2 gap-3 max-w-3xl">
      {sharedStandards.map((s) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-champagne text-xs">—</span><span>{s}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="How Future Academies Will Be Built" title="Field-led, institutionally supported.">
    <div class="prose-editorial max-w-3xl">
      <p>Each future academy will be developed in collaboration with experienced practitioners and educators in that field. The shared institutional framework — governance, evidence standards, documentation, and review — is provided by Academia Europa. Field-specific content, curriculum, and faculty are led by the academy.</p>
    </div>
  </Section>

  <Section eyebrow="Collaborate on a Future Academy" tone="ivory">
    <div class="prose-editorial max-w-3xl">
      <p>Experts, institutions, and organisations interested in collaborating on the development of a future academy are welcome to contact the academic office.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/partnerships" class="btn">Partnerships & Academic Review</a>
        <a href="mailto:academic@academiaeuropa.com" class="btn">Email the Academic Office</a>
      </div>
    </div>
  </Section>
</Base>
