---
const year = new Date().getFullYear();
const cols = [
  {
    title: 'Institution',
    links: [
      { href: '/about', label: 'About' },
      { href: '/about/leadership', label: 'Leadership' },
      { href: '/educational-philosophy', label: 'Educational Philosophy' },
      { href: '/institutional-profile', label: 'Institutional Profile' },
    ],
  },
  {
    title: 'Standards',
    links: [
      { href: '/academic-standards', label: 'Academic Standards' },
      { href: '/academic-governance', label: 'Academic Governance' },
      { href: '/partnerships', label: 'Partnerships' },
      { href: '/faculty', label: 'Faculty' },
    ],
  },
  {
    title: 'Academies',
    links: [
      { href: '/academies', label: 'Professional Academies' },
      { href: '/academies/vai', label: 'VAI' },
      { href: 'https://vai.vet', label: 'Visit VAI', external: true },
    ],
  },
  {
    title: 'Engage',
    links: [
      { href: '/insights', label: 'Insights' },
      { href: '/contact', label: 'Contact' },
    ],
  },
];
---
<footer class="bg-navy-deep text-ivory mt-32">
  <div class="container-prose py-20">
    <!-- Brand bar -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 pb-12 border-b border-navy-soft">
      <a href="/" class="flex items-center" aria-label="Academia Europa">
        <img
          src="/academia-europa-logo.svg"
          alt="Academia Europa"
          class="h-14 w-auto"
          style="filter: invert(1); mix-blend-mode: screen;"
        />
      </a>
      <div class="text-[11px] tracking-[0.18em] uppercase text-platinum/80 max-w-md md:text-right">
        A European institution for structured postgraduate professional education
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-12 pt-14">
      {cols.map((c) => (
        <div>
          <div class="eyebrow text-champagne-soft mb-5">{c.title}</div>
          <ul class="space-y-3 text-sm text-platinum">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="hover:text-ivory transition-colors"
                  {...(l.external ? { rel: 'noopener', target: '_blank' } : {})}
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Legal strip -->
    <div class="mt-16 pt-8 border-t border-navy-soft">
      <p class="max-w-4xl text-xs text-platinum/80 leading-relaxed">
        Academia Europa is operated by Solex Education Unipessoal LDA, Portugal, and develops structured postgraduate professional education across specialised fields.
      </p>
      <div class="mt-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-platinum/60">
        <div>© {year} Academia Europa.</div>
        <div class="flex gap-6">
          <a href="/legal/privacy" class="hover:text-ivory">Privacy</a>
          <a href="/legal/terms" class="hover:text-ivory">Terms</a>
          <a href="/legal/cookies" class="hover:text-ivory">Cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>
