---
const year = new Date().getFullYear();
const cols = [
  {
    title: 'Institution',
    links: [
      { href: '/about', label: 'About' },
      { href: '/about/founder', label: 'Founder' },
      { href: '/educational-philosophy', label: 'Educational Philosophy' },
      { href: '/academic-standards', label: 'Academic Standards' },
    ],
  },
  {
    title: 'Academies',
    links: [
      { href: '/academies', label: 'Professional Academies' },
      { href: '/academies/vai', label: 'VAI' },
      { href: '/academies/vai/veterinary-longevity', label: 'Veterinary Longevity' },
    ],
  },
  {
    title: 'Engage',
    links: [
      { href: '/faculty', label: 'Faculty' },
      { href: '/partnerships', label: 'Partnerships' },
      { href: '/insights', label: 'Insights' },
      { href: '/contact', label: 'Contact' },
    ],
  },
];
---
<footer class="bg-navy-deep text-ivory mt-32">
  <div class="container-prose py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div>
        <img src="/academia-europa-logo.svg" alt="Academia Europa" class="h-16 w-auto mb-5" style="filter: brightness(0) invert(1);" />
        <p class="text-sm text-platinum leading-relaxed max-w-xs">
          A European institution for structured postgraduate professional education.
        </p>
      </div>
      {cols.map((c) => (
        <div>
          <div class="eyebrow text-champagne-soft mb-4">{c.title}</div>
          <ul class="space-y-2 text-sm text-platinum">
            {c.links.map((l) => (
              <li><a href={l.href} class="hover:text-ivory transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-16 pt-8 border-t border-navy-soft text-xs text-platinum/80 leading-relaxed flex flex-col md:flex-row md:justify-between gap-4">
      <div>
        © {year} Academia Europa. Operated by Solex Education Unipessoal LDA, Portugal.
      </div>
      <div class="flex gap-6">
        <a href="/legal/privacy" class="hover:text-ivory">Privacy</a>
        <a href="/legal/terms" class="hover:text-ivory">Terms</a>
        <a href="/legal/cookies" class="hover:text-ivory">Cookies</a>
      </div>
    </div>
  </div>
</footer>
