---
const year = new Date().getFullYear();
const cols = [
  {
    title: 'Institution',
    links: [
      { href: '/about', label: 'About' },
      { href: '/about/leadership', label: 'Leadership' },
      { href: '/educational-philosophy', label: 'Educational Philosophy' },
      { href: '/institutional-profile', label: 'Institutional Profile' },
    ],
  },
  {
    title: 'Standards',
    links: [
      { href: '/academic-standards', label: 'Academic Standards' },
      { href: '/academic-governance', label: 'Academic Governance' },
      { href: '/partnerships', label: 'Partnerships' },
      { href: '/faculty', label: 'Faculty' },
    ],
  },
  {
    title: 'Academies',
    links: [
      { href: '/academies', label: 'Professional Academies' },
      { href: '/academies/vai', label: 'VAI' },
      { href: 'https://vai.vet', label: 'Visit VAI', external: true },
    ],
  },
  {
    title: 'Engage',
    links: [
      { href: '/insights', label: 'Insights' },
      { href: '/contact', label: 'Contact' },
    ],
  },
];
---
<footer style="background-color: var(--color-charcoal-deep);">
  <div class="container-prose py-14">
    <!-- Brand bar -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 pb-10">
      <a href="/" class="flex items-center" aria-label="Academia Europa">
        <img
          src="/academia-europa-logo.svg"
          alt="Academia Europa"
          class="h-14 w-auto"
          style="filter: invert(1) sepia(0.1); mix-blend-mode: lighten;"
        />
      </a>
      <div class="text-[11px] tracking-[0.18em] uppercase text-stone max-w-md md:text-right">
        Structured postgraduate education for professional mastery.
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-0 h-px" style="background-color: var(--color-divider);" />

    <!-- Link columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-12 pt-12">
      {cols.map((c) => (
        <div>
          <div class="eyebrow mb-5">{c.title}</div>
          <ul class="space-y-3 text-sm text-cream-dim">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="hover:text-cream transition-colors"
                  {...(l.external ? { rel: 'noopener', target: '_blank' } : {})}
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Legal strip -->
    <div class="mt-14 pt-8 border-t" style="border-color: var(--color-divider);">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-stone">
        <div>© {year} Academia Europa.</div>
        <div class="flex gap-6">
          <a href="/legal/privacy" class="hover:text-cream">Privacy</a>
          <a href="/legal/terms" class="hover:text-cream">Terms</a>
          <a href="/legal/cookies" class="hover:text-cream">Cookies</a>
        </div>
      </div>
      <p class="mt-8 text-center text-[11px] text-stone leading-relaxed">
        Academia Europa is operated by Solex Education Unipessoal LDA, Portugal. Registered professional education institution.
      </p>
    </div>
  </div>
</footer>
