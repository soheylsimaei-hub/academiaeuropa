---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  tone?: 'light' | 'dark';
}
const { eyebrow, title, lede, tone = 'light' } = Astro.props;
const bg = tone === 'dark' ? 'bg-navy-deep text-cream' : 'bg-ivory';
const titleColor = tone === 'dark' ? 'text-cream' : 'text-cream';
const ledeColor = tone === 'dark' ? 'text-cream-dim' : 'text-graphite';
---
<section class={`${bg} border-b border-platinum-soft/60`}>
  <div class="container-prose py-8 md:py-12">
    {eyebrow && <div class="eyebrow mb-6">{eyebrow}</div>}
    <h1 class={`font-serif ${titleColor} text-4xl md:text-6xl leading-[1.05] max-w-5xl`}>
      {title}
    </h1>
    {lede && (
      <p class={`mt-8 max-w-5xl text-lg md:text-xl leading-relaxed ${ledeColor}`}>{lede}</p>
    )}
  </div>
</section>
