---
interface Props {
  eyebrow?: string;
  title?: string;
  tone?: 'paper' | 'ivory' | 'navy';
  align?: 'left' | 'center';
}
const { eyebrow, title, tone = 'paper', align = 'left' } = Astro.props;
const bg = tone === 'navy' ? 'bg-navy-deep' : tone === 'ivory' ? 'bg-ivory' : 'bg-paper';
const alignClass = align === 'center' ? 'text-center mx-auto' : '';
---
<section class={bg}>
  <div class="container-prose py-12 md:py-16">
    {(eyebrow || title) && (
      <div class={`${alignClass} mb-8 max-w-5xl`}>
        {eyebrow && <div class="eyebrow mb-4">{eyebrow}</div>}
        {title && (
          <h2 class="font-serif text-cream text-3xl md:text-5xl leading-[1.1]">{title}</h2>
        )}
        <div class={`rule-gold mt-6 ${align === 'center' ? 'mx-auto' : ''}`}></div>
      </div>
    )}
    <slot />
  </div>
</section>
